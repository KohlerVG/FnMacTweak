#!/bin/sh
# postinst — runs automatically after every package install/upgrade
# Writes the installed version into NSUserDefaults so FnMacTweak can
# detect version bumps at runtime and re-show the welcome popup.

PACKAGE="com.yourcompany.fnmactweak"
VERSION=$(dpkg-query -f '${Version}' -W "$PACKAGE" 2>/dev/null)

if [ -n "$VERSION" ]; then
    # Write to all known Fortnite NSUserDefaults domains so the version
    # key is present regardless of which container the app reads from.
    defaults write com.epicgames.FortniteGame.57R7T7Q6F9 fnmactweak.version "$VERSION"
    defaults write com.epicgames.FortniteGame.FC2QCLNL95 fnmactweak.version "$VERSION"
fi

exit 0
